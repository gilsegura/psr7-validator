{
    "name": "gilsegura/psr7-validator",
    "description": "This is a project providing infrastructure for validating PSR-7 requests.",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "beberlei/assert": "^3.3",
        "psr/http-message": "^2.0",
        "justinrainbow/json-schema": "^6.0",
        "psr/http-server-middleware": "^1.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.49",
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "rector/rector": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "PSR7Validator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PSR7Validator\\Tests\\": "tests/"
        }
    }
}
